### DOMRS API Testing File
### Use VS Code "REST Client" or "Thunder Client" to run directly.
### Run the login blocks first to capture tokens, then use them in subsequent requests.
####
@baseUrl = http://localhost:3001

# ==========================================
# HEALTH CHECK
# ==========================================

### Health Check
GET {{baseUrl}}/
Accept: application/json


# ==========================================
# 1. AUTHENTICATION — Login all roles
# ==========================================

### [BUG4] Login as EOC Admin (demo account)
# @name loginEoc
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "admin@domrs.test",
    "password": "Admin1234"
}

### Login as PHO (pho@domrs.test / PHO1234)
# @name loginPho
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "pho@domrs.test",
    "password": "PHO1234"
}

### Login as Hospital 1
# @name loginHospital
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "hospital1@domrs.test",
    "password": "Hospital1234"
}

### Login as Civilian
# @name loginCivilian
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "civilian@domrs.test",
    "password": "Civilian1234"
}

# ── Token shortcuts ──
@eocToken      = {{loginEoc.response.body.session.access_token}}
@phoToken      = {{loginPho.response.body.session.access_token}}
@instToken     = {{loginHospital.response.body.session.access_token}}


# ==========================================
# 2. [BUG1] COMMUNITY REPORT — NO AUTH NEEDED
# Must return 201 with zero auth headers
# ==========================================

### [BUG1] Community report — completely anonymous, no Authorization header
POST {{baseUrl}}/reports/community
Content-Type: application/json

{
    "lga": "Surulere",
    "symptoms": ["fever", "headache", "cough"],
    "severity": 6,
    "reporter_name": "Anonymous Resident",
    "notes": "Several neighbours have been ill since Monday"
}


# ==========================================
# 3. [BUG2] INSTITUTION SENTINEL REPORT
# Must return 201 with { report, alert }
# ==========================================

### [BUG2] Institution sentinel report — requires institution JWT
POST {{baseUrl}}/reports
Content-Type: application/json
Authorization: Bearer {{instToken}}

{
    "patientCount": 12,
    "originLocation": {
        "lat": 6.5244,
        "lng": 3.3792,
        "address": "Surulere General Hospital, Lagos"
    },
    "symptomMatrix": ["Fever", "Vomiting", "Diarrhoea", "Fatigue"],
    "severity": 8,
    "source": "institution",
    "notes": "Cluster of suspected cholera cases — 4 admitted, 8 outpatient"
}

### View institution's own report feed
GET {{baseUrl}}/reports/feed
Authorization: Bearer {{instToken}}

### View institution analytics
GET {{baseUrl}}/reports/analytics
Authorization: Bearer {{instToken}}


# ==========================================
# 4. EOC ALERT MANAGEMENT
# ==========================================

### EOC: Fetch alert inbox
GET {{baseUrl}}/alerts/inbox
Authorization: Bearer {{eocToken}}

### EOC: Update alert status (replace UUID with a real alert id)
PATCH {{baseUrl}}/alerts/00000000-0000-0000-0000-000000000001/status
Content-Type: application/json
Authorization: Bearer {{eocToken}}

{
    "status": "confirmed"
}

### [BUG5] EOC: Broadcast advisory to all institutions
POST {{baseUrl}}/alerts/broadcast
Content-Type: application/json
Authorization: Bearer {{eocToken}}

{
    "message": "EOC Advisory: Elevated respiratory illness in Lagos Mainland. All facilities must increase surveillance and report clusters immediately."
}


# ==========================================
# 5. [BUG4] PHO OPERATIONS
# PHO has same access as EOC for alerts
# ==========================================

### [BUG4] PHO: Fetch alert inbox
GET {{baseUrl}}/alerts/inbox
Authorization: Bearer {{phoToken}}

### [BUG4] PHO: Claim an alert (replace UUID with a real alert id)
POST {{baseUrl}}/alerts/00000000-0000-0000-0000-000000000001/claim
Authorization: Bearer {{phoToken}}

### [BUG4] PHO: Broadcast advisory
POST {{baseUrl}}/alerts/broadcast
Content-Type: application/json
Authorization: Bearer {{phoToken}}

{
    "message": "PHO Advisory: Enteric outbreak suspected in Ikeja zone. Facilities implement contact tracing immediately."
}

### [BUG4] PHO: Update alert status
PATCH {{baseUrl}}/alerts/00000000-0000-0000-0000-000000000001/status
Content-Type: application/json
Authorization: Bearer {{phoToken}}

{
    "status": "probable"
}

### [BUG4] PHO: Escalate alert to EOC
POST {{baseUrl}}/alerts/00000000-0000-0000-0000-000000000001/escalate
Authorization: Bearer {{phoToken}}


# ==========================================
# 6. PUBLIC ENDPOINTS
# ==========================================

### National trends (public)
GET {{baseUrl}}/alerts/national

### Local alerts (public — requires auth token but no role restriction)
GET {{baseUrl}}/alerts/local?lat=6.5244&lng=3.3792
Authorization: Bearer {{phoToken}}


# ==========================================
# 7. EOC ADMIN OPERATIONS
# ==========================================

### EOC: System logs
GET {{baseUrl}}/admin/logs?limit=50
Authorization: Bearer {{eocToken}}

### EOC: User list
GET {{baseUrl}}/admin/users
Authorization: Bearer {{eocToken}}

### EOC: User list — filter PHO only
GET {{baseUrl}}/admin/users?role=pho
Authorization: Bearer {{eocToken}}

### EOC: Institution registrations (for EOC map + dashboard)
GET {{baseUrl}}/institutions
Authorization: Bearer {{eocToken}}
